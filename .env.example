# Database Configuration
DATABASE_URL=sqlite:///./web_emotion_chat.db
# DATABASE_URL=postgresql://user:password@localhost:5432/emotion_chat

# llama-server LLM Configuration
LLAMA_SERVER_BASE_URL=http://localhost:8080
DEFAULT_LLM_MODEL=qwen2.5-1.5b-chat-tamly-markdown-withemotion:latest

# Hugging Face Configuration (for downloading models)
# Get token from: https://huggingface.co/settings/tokens
HF_TOKEN=hf_your_token_here

# Whisper Speech-to-Text Configuration
# Uncomment to use custom Whisper model from HF Hub
# WHISPER_MODEL_ID=openai/whisper-small
# Or use local model:
# WHISPER_MODEL_DIR=./whisper_model

# Database retry configuration (for Docker/Postgres)
DB_CONNECT_MAX_RETRIES=20
DB_CONNECT_RETRY_SECONDS=2
